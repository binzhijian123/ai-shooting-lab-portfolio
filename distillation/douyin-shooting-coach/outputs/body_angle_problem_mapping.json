    },
    {
      "observation_id": "upper_body.front_line_deviation",
      "name": "正面肩肘腕力线偏差",
      "evidence_family": "geometry",
      "angle_ids": ["body.forearm_from_vertical", "body.elbow_flexion_extension"],
      "evaluation_mode": "front_view_line_geometry",
      "required_metrics": ["shoulder_elbow_wrist_lateral_error_ratio"],
