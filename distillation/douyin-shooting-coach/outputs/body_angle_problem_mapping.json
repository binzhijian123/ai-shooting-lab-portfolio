      "standalone_diagnosis_allowed": false
    }
  ],
  "problem_mappings": [
    {
      "problem_id": "problem.lower_body_load_insufficient",
      "name": "下肢准备负荷不足候选",
      "body_chain_segment": "lower_body_loading",
      "required_views": ["side"],
      "required_observation_groups": [
        ["lower_body.flexion_rom_low"],
        ["output.com_vertical_rise_low", "output.release_height_low"]
      ],
      "supporting_observations": ["timing.ball_lift_precedes_lower_body"],
      "minimum_evidence_families": 2,
      "supported_repeatability_ratio": 0.6,
      "inference": "下肢准备屈曲和垂直输出同时不足时，才检索下肢加载不足问题；浅屈曲本身不判错。",
      "knowledge_query": {
        "tags": ["lower_body_power", "hip", "knee", "ankle/foot", "power_chain"],
        "terms": ["下肢发力不足", "屈髋", "屈膝", "蓄力不足", "远投力量不足"],
        "app_modules": ["shot_diagnosis", "training_repair"],
        "minimum_term_matches": 1,
        "top_k": 5
      },
      "false_positive_checks": ["近距离投篮可能不需要明显下沉。", "个人一段式动作可能使用较小屈曲但仍保持有效输出。"]
    },
    {
      "problem_id": "problem.excessive_slow_loading",
      "name": "下肢加载过深且转化偏慢候选",
      "body_chain_segment": "lower_body_loading",
      "required_views": ["side"],
      "required_observation_groups": [
        ["lower_body.flexion_rom_high"],
        ["triple_extension.pause_or_reversal", "triple_extension.peak_timing_dispersion"],
        ["timing.ball_lift_lags_lower_body", "output.com_vertical_rise_low"]
      ],
      "supporting_observations": ["knee.extension_dominance"],
      "minimum_evidence_families": 2,
      "supported_repeatability_ratio": 0.6,
      "inference": "深屈曲必须同时伴随停顿、时序分散或输出不足，才检索空蹲和二次蓄力问题。",
      "knowledge_query": {
        "tags": ["lower_body_power", "knee", "hip", "timing", "power_chain"],
        "terms": ["过度屈膝", "二次蓄力", "空蹲", "起跳慢", "下肢发力节奏"],
        "app_modules": ["shot_diagnosis", "training_repair"],
        "minimum_term_matches": 1,
        "top_k": 5
      },
      "false_positive_checks": ["三分球可能需要更大的准备屈曲。", "只有深度而没有慢速或停顿时不得判定低效。"]
    },
    {
      "problem_id": "problem.knee_dominant_extension",
      "name": "膝主导三关节伸展候选",
      "body_chain_segment": "triple_extension",
      "required_views": ["side"],
      "required_observation_groups": [
        ["knee.extension_dominance"],
        ["hip.extension_contribution_low", "ankle.terminal_extension_low"],
        ["output.com_vertical_rise_low", "timing.ball_lift_precedes_lower_body", "triple_extension.pause_or_reversal"]
      ],
      "supporting_observations": ["lower_body.flexion_rom_high"],
      "minimum_evidence_families": 2,
      "supported_repeatability_ratio": 0.6,
      "inference": "膝的相对贡献偏高、髋或踝参与偏低，并伴随输出或时序异常时，检索膝主导和力量卡在膝部的问题。",
      "knowledge_query": {
        "tags": ["knee", "hip", "ankle/foot", "lower_body_power", "power_chain"],
        "terms": ["膝盖发力", "膝主导", "过度屈膝", "髋关节", "脚踝"],
        "app_modules": ["shot_diagnosis", "training_repair"],
        "minimum_term_matches": 1,
        "top_k": 5
      },
      "false_positive_checks": ["2D角度不能直接等同于关节力矩或肌肉贡献。", "疲劳、疼痛和投篮距离会改变关节贡献。"]
    },
    {
      "problem_id": "problem.hip_extension_contribution_low",
      "name": "髋伸展参与不足候选",
      "body_chain_segment": "triple_extension",
      "required_views": ["side"],
      "required_observation_groups": [
        ["hip.extension_contribution_low"],
