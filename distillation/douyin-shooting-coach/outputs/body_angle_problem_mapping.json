      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "wrist.late_lateral_correction",
      "name": "出手末段手腕出现横向修正",
      "evidence_family": "coordination",
      "angle_ids": ["body.wrist_flexion_extension"],
