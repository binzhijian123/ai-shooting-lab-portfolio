{
  "schema_version": "body_angle_problem_mapping.v1",
  "version": "0.1.0",
  "updated_at": "2026-06-19",
  "source_contract": "body_angle_curve_to_observation_to_problem_candidate_to_knowledge_retrieval",
  "policy": {
    "no_universal_ideal_angle": true,
    "no_single_angle_diagnosis": true,
    "no_final_total_score": true,
    "missing_evidence_is_not_negative": true,
    "minimum_evidence_families_for_candidate": 2,
    "paper_values_are_context_priors_not_error_thresholds": true,
    "preferred_baseline_order": [
      "same_player_same_shot_context",
      "local_peer_group_same_context",
      "peer_reviewed_paper_same_context",
      "engineering_provisional"
    ]
  },
  "baseline_contract": {
    "baseline_key_fields": [
      "player_id",
      "shot_type",
      "distance_band",
      "camera_view",
      "fps_band",
      "dominant_hand"
    ],
    "statistics": ["median", "mad", "p10", "p90", "valid_attempt_count"],
    "sample_status": {
      "0-4": "paper_prior_and_within_attempt_relations_only",
      "5-9": "provisional_personal_baseline",
      "10-19": "usable_personal_baseline",
      "20+": "stable_personal_baseline_candidate"
    },
    "provisional_deviation_policy": {
      "formula": "robust_z = abs(value - median) / (1.4826 * MAD)",
      "observed_when": "robust_z >= 2",
      "strong_when": "robust_z >= 3",
      "status": "engineering_provisional_not_research_validated",
      "warning": "Do not treat these statistical boundaries as universal basketball technique standards."
    },
    "curve_comparison": {
      "phase_normalization": "normalize preparation_start_to_release to 0..100 percent",
      "features": [
        "minimum_angle",
        "range_of_motion",
        "extension_onset_percent",
        "peak_angular_velocity",
        "peak_velocity_percent",
        "extension_progress_at_release",
        "pause_or_reversal_count",
        "curve_distance_to_personal_median"
      ]
    }
  },
  "research_sources": [
    {
      "source_id": "cabarkapa_2026_three_point_markerless",
      "title": "Biomechanical determinants of proficient 3-point shooters: markerless motion capture analysis",
      "url": "https://www.frontiersin.org/journals/sports-and-active-living/articles/10.3389/fspor.2026.1732293/full",
      "supports": [
        "preparatory hip knee ankle angles",
        "joint range of motion",
        "hip angular velocity",
        "center of mass change",
        "shot-context-specific interpretation"
      ],
      "does_not_support": "A universal pass/fail angle for all shooters or shot types."
    },
    {
      "source_id": "nakano_2018_basketball_energy_flow",
      "title": "The effect of increased shooting distance on energy flow in basketball jump shot",
      "url": "https://pubmed.ncbi.nlm.nih.gov/30001184/",
      "supports": [
        "distance changes lower-limb work demand",
        "lower-limb to shooting-arm energy transfer as a useful mechanism"
      ],
      "does_not_support": "Inferring joint work or energy transfer from a single 2D angle alone."
    },
    {
      "source_id": "okazaki_2012_distance_kinematics",
      "title": "Increased distance of shooting on basketball jump shot",
      "url": "https://www.jssm.org/volume11/iss2/cap/jssm-11-231.pdf",
      "supports": [
        "distance-specific joint angular displacement",
        "distance-specific joint angular velocity",
        "release context"
      ],
      "does_not_support": "Reusing one distance's angle values for every shot distance."
    },
    {
      "source_id": "kipp_2012_weightlifting_synergies",
      "title": "Kinematic and Kinetic Synergies of the Lower Extremities During the Pull in Olympic Weightlifting",
      "url": "https://doi.org/10.1123/jab.28.3.271",
      "supports": [
        "whole-curve multijoint analysis",
        "hip knee ankle synergy as a dynamic pattern"
      ],
      "does_not_support": "Copying clean triple-extension angles into basketball shooting."
    },
    {
      "source_id": "chen_2019_snatch_vector_coding",
      "title": "Weightlifting load effect on intra-limb coordination of lower extremity during pull phase in snatch: Vector coding approach",
      "url": "https://pubmed.ncbi.nlm.nih.gov/31221023/",
      "supports": [
        "angle-angle plots",
        "vector-coding coordination",
        "task and load dependent coupling"
      ],
      "does_not_support": "A fixed universal proximal-to-distal timing threshold for shooting."
    },
    {
      "source_id": "mullineaux_2010_elbow_wrist_variability",
      "title": "Coordination-variability and kinematics of misses versus swishes of basketball free throws",
      "url": "https://doi.org/10.1080/02640414.2010.487872",
      "supports": ["elbow-wrist angle-angle coordination variability near release"],
      "does_not_support": "Reliable late-release diagnosis from ordinary 30 fps video."
    }
  ],
  "angle_definitions": [
    {
      "angle_id": "body.hip_flexion_extension",
      "name": "髋关节屈伸角",
      "vertex": "hip",
      "points": ["shoulder", "hip", "knee"],
      "required_view": ["side"],
      "required_landmarks": ["shoulder", "hip", "knee"],
      "interpretation": "躯干与大腿之间的内角，用于观察屈髋加载和伸髋过程。"
    },
    {
      "angle_id": "body.knee_flexion_extension",
      "name": "膝关节屈伸角",
      "vertex": "knee",
      "points": ["hip", "knee", "ankle"],
      "required_view": ["side"],
      "required_landmarks": ["hip", "knee", "ankle"],
      "interpretation": "大腿与小腿之间的内角，用于观察屈膝加载和伸膝过程。"
    },
    {
      "angle_id": "body.ankle_dorsi_plantar_flexion",
      "name": "踝关节屈伸角",
      "vertex": "ankle",
      "points": ["knee", "ankle", "forefoot"],
      "required_view": ["side"],
      "required_landmarks": ["knee", "ankle", "heel", "forefoot"],
      "interpretation": "小腿与足部之间的角度；没有脚跟和前脚掌时不可判断。"
    },
    {
      "angle_id": "body.trunk_lean_from_vertical",
      "name": "躯干相对垂直角",
      "vertex": "hip_midpoint",
      "points": ["shoulder_midpoint", "hip_midpoint", "vertical_reference"],
      "required_view": ["side"],
      "required_landmarks": ["left_shoulder", "right_shoulder", "left_hip", "right_hip"],
      "interpretation": "整体躯干倾斜代理，不等同于直接测量腰椎角。"
    },
    {
      "angle_id": "body.upper_arm_to_trunk",
      "name": "大臂与躯干夹角",
      "vertex": "shoulder",
      "points": ["elbow", "shoulder", "hip"],
      "required_view": ["side"],
      "required_landmarks": ["elbow", "shoulder", "hip"],
      "interpretation": "用于观察大臂抬起和释放空间，不能脱离肘高与出手高度解释。"
    },
    {
      "angle_id": "body.elbow_flexion_extension",
      "name": "肘关节屈伸角",
      "vertex": "elbow",
      "points": ["shoulder", "elbow", "wrist"],
      "required_view": ["side", "front"],
      "required_landmarks": ["shoulder", "elbow", "wrist"],
      "interpretation": "大臂与前臂之间的内角，用于观察折叠、伸肘时机和速度。"
    },
    {
      "angle_id": "body.forearm_from_vertical",
      "name": "前臂相对垂直角",
      "vertex": "elbow",
      "points": ["elbow", "wrist", "vertical_reference"],
      "required_view": ["front", "side"],
      "required_landmarks": ["elbow", "wrist"],
      "interpretation": "前臂方向代理；正面视角优先用于横向偏差。"
    },
    {
      "angle_id": "body.wrist_flexion_extension",
      "name": "手腕屈伸角",
      "vertex": "wrist",
      "points": ["elbow", "wrist", "middle_finger_mcp"],
      "required_view": ["side", "front"],
      "required_landmarks": ["elbow", "wrist", "middle_finger_mcp"],
      "interpretation": "需要手部关键点；只有腕点时不可判断压腕角。"
    }
  ],
  "observation_definitions": [
    {
      "observation_id": "lower_body.flexion_rom_low",
      "name": "下肢准备屈曲范围相对偏小",
      "evidence_family": "geometry",
      "angle_ids": ["body.hip_flexion_extension", "body.knee_flexion_extension", "body.ankle_dorsi_plantar_flexion"],
      "evaluation_mode": "personal_or_peer_curve_baseline",
      "required_metrics": ["hip_rom_deg", "knee_rom_deg", "ankle_rom_deg"],
      "direction": "below_context_reference",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "lower_body.flexion_rom_high",
      "name": "下肢准备屈曲范围相对偏大",
      "evidence_family": "geometry",
      "angle_ids": ["body.hip_flexion_extension", "body.knee_flexion_extension"],
      "evaluation_mode": "personal_or_peer_curve_baseline",
      "required_metrics": ["hip_rom_deg", "knee_rom_deg"],
      "direction": "above_context_reference",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "lower_body.extension_output_present",
      "name": "下肢存在连续伸展输出",
      "evidence_family": "geometry",
      "angle_ids": ["body.hip_flexion_extension", "body.knee_flexion_extension", "body.ankle_dorsi_plantar_flexion"],
      "evaluation_mode": "within_attempt_relation",
      "required_metrics": ["hip_rom_deg", "knee_rom_deg", "ankle_rom_deg", "lower_body_extension_duration_ms"],
      "direction": "all_joints_extend_without_reversal",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "knee.extension_dominance",
      "name": "伸展过程呈膝主导",
      "evidence_family": "geometry",
      "angle_ids": ["body.hip_flexion_extension", "body.knee_flexion_extension", "body.ankle_dorsi_plantar_flexion"],
      "evaluation_mode": "within_attempt_joint_share_then_personal_baseline",
      "required_metrics": ["knee_rom_share", "knee_extension_duration_share", "knee_peak_velocity_share"],
      "direction": "knee_share_above_context_reference",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "hip.extension_contribution_low",
      "name": "髋伸展参与相对不足",
      "evidence_family": "geometry",
      "angle_ids": ["body.hip_flexion_extension"],
      "evaluation_mode": "personal_or_peer_curve_baseline",
      "required_metrics": ["hip_rom_deg", "hip_peak_angular_velocity_deg_s"],
      "direction": "below_context_reference",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "ankle.terminal_extension_low",
      "name": "踝关节末端伸展参与相对不足",
      "evidence_family": "geometry",
      "angle_ids": ["body.ankle_dorsi_plantar_flexion"],
      "evaluation_mode": "personal_or_peer_curve_baseline",
      "required_metrics": ["ankle_rom_deg", "ankle_peak_angular_velocity_deg_s", "heel_rise_ratio"],
      "direction": "below_context_reference",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "triple_extension.pause_or_reversal",
      "name": "三关节伸展出现停顿或反向",
      "evidence_family": "coordination",
      "angle_ids": ["body.hip_flexion_extension", "body.knee_flexion_extension", "body.ankle_dorsi_plantar_flexion"],
      "evaluation_mode": "within_attempt_curve_shape",
      "required_metrics": ["lower_body_pause_count", "lower_body_reversal_count"],
      "direction": "pause_or_reversal_present",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "triple_extension.peak_timing_dispersion",
      "name": "三关节峰值速度时序分散",
      "evidence_family": "coordination",
      "angle_ids": ["body.hip_flexion_extension", "body.knee_flexion_extension", "body.ankle_dorsi_plantar_flexion"],
      "evaluation_mode": "personal_or_peer_timing_baseline",
      "required_metrics": ["hip_peak_velocity_time_ms", "knee_peak_velocity_time_ms", "ankle_peak_velocity_time_ms"],
      "direction": "dispersion_above_context_reference",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "timing.ball_lift_precedes_lower_body",
      "name": "起球早于下肢有效伸展",
      "evidence_family": "coordination",
      "angle_ids": ["body.hip_flexion_extension", "body.knee_flexion_extension", "body.ankle_dorsi_plantar_flexion"],
      "evaluation_mode": "signed_event_order",
      "required_metrics": ["ball_lift_minus_lower_body_onset_ms"],
      "direction": "negative",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "timing.ball_lift_lags_lower_body",
      "name": "起球明显晚于下肢有效伸展",
      "evidence_family": "coordination",
      "angle_ids": ["body.hip_flexion_extension", "body.knee_flexion_extension", "body.ankle_dorsi_plantar_flexion"],
      "evaluation_mode": "personal_or_peer_timing_baseline",
      "required_metrics": ["ball_lift_minus_lower_body_onset_ms"],
      "direction": "positive_above_context_reference",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "output.com_vertical_rise_low",
      "name": "重心垂直上升输出相对不足",
      "evidence_family": "output",
      "angle_ids": [],
      "evaluation_mode": "personal_or_peer_output_baseline",
      "required_metrics": ["com_vertical_rise_ratio", "com_peak_vertical_velocity"],
      "direction": "below_context_reference",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "output.release_height_low",
      "name": "释放高度相对偏低",
      "evidence_family": "output",
      "angle_ids": ["body.upper_arm_to_trunk", "body.elbow_flexion_extension"],
      "evaluation_mode": "same_player_same_shot_context",
      "required_metrics": ["release_height_ratio"],
      "direction": "below_context_reference",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "trunk.forward_lean_increase",
      "name": "出手阶段躯干前倾增加",
      "evidence_family": "geometry",
      "angle_ids": ["body.trunk_lean_from_vertical"],
      "evaluation_mode": "curve_delta_then_personal_baseline",
      "required_metrics": ["trunk_lean_change_deg", "trunk_lean_release_deg"],
      "direction": "above_context_reference",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "trunk.forward_drift",
      "name": "髋部或重心水平前移增加",
      "evidence_family": "output",
      "angle_ids": ["body.trunk_lean_from_vertical"],
      "evaluation_mode": "same_player_same_shot_context",
      "required_metrics": ["center_of_mass_forward_drift_cm"],
      "direction": "above_context_reference",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "upper_arm.preparation_height_low",
      "name": "准备阶段大臂抬起和肘高相对偏低",
      "evidence_family": "geometry",
      "angle_ids": ["body.upper_arm_to_trunk"],
      "evaluation_mode": "same_player_same_shot_context",
      "required_metrics": ["upper_arm_to_trunk_deg", "elbow_height_ratio"],
      "direction": "below_context_reference",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "elbow.extension_onset_early",
      "name": "肘部伸展相对起球或下肢提前",
      "evidence_family": "coordination",
      "angle_ids": ["body.elbow_flexion_extension"],
      "evaluation_mode": "signed_event_order",
      "required_metrics": ["elbow_extension_minus_ball_lift_ms", "elbow_extension_minus_lower_body_onset_ms"],
      "direction": "negative_outside_context_band",
      "standalone_diagnosis_allowed": false
    },
    {
      "observation_id": "forearm.lateral_deviation",
      "name": "前臂方向出现横向偏差",
      "evidence_family": "geometry",
      "angle_ids": ["body.forearm_from_vertical"],
      "evaluation_mode": "front_view_personal_or_peer_baseline",
      "required_metrics": ["forearm_from_vertical_deg"],
      "direction": "absolute_deviation_above_context_reference",
